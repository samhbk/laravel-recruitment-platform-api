APP_NAME="Laravel Recruitment Platform API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database — pick ONE connection (SQLite is simplest for local dev / PHPUnit)
# ---------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE is optional for SQLite file mode; PHPUnit uses :memory: via phpunit.xml

# MySQL 8 (Docker Compose or local)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3307
# DB_DATABASE=recruitment
# DB_USERNAME=recruitment
# DB_PASSWORD=recruitment

# PostgreSQL (supported via Laravel; no extra driver required for PDO)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=recruitment
# DB_USERNAME=recruitment
# DB_PASSWORD=recruitment

SESSION_DRIVER=array
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Redis — used by Docker Compose for CACHE_STORE; PHPUnit uses array (phpunit.xml)
CACHE_STORE=database
# CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# JWT — required: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60
